{
  "schema_version": "1",
  "gateway": {
    "instance_name": "demo",
    "data_dir": "./data"
  },
  "opcua": {
    "enabled": true,
    "host": "0.0.0.0",
    "advertised_host": "192.168.0.2",
    "port": 4840,
    "application_name": "OPC Modbus Server (demo)",
    "allow_none_security": true,
    "basic256sha256": true,
    "allow_anonymous": true,
    "users": [
      {
        "username": "operator",
        "password_hash": "$argon2id$v=19$m=19456,t=2,p=1$LWmjc1YI/MbAPRf6PQes/A$H8H3rOu0f+sq2lv7yrrg1l6F+niBCzsBRf5Df38Yx0A"
      }
    ],
    "pki_dir": "pki",
    "trust_any_client_cert": false
  },
  "logging": {
    "level": "info",
    "dir": "./logs"
  },
  "poll_groups": [
    {
      "id": "fast",
      "period_ms": 500
    },
    {
      "id": "slow",
      "period_ms": 5000
    }
  ],
  "channels": [
    {
      "id": "plc-tcp",
      "transport": {
        "type": "tcp",
        "host": "192.168.0.10",
        "port": 502
      },
      "request_timeout_ms": 1000,
      "devices": [
        {
          "id": "plc1",
          "unit_id": 1,
          "registers": [
            {
              "tag": "plc1.temperature",
              "poll_group": "fast",
              "function": "read_holding_registers",
              "address": 0,
              "data_type": "i16",
              "scale": 0.1,
              "units": "degC",
              "deadband": 0.2
            },
            {
              "tag": "plc1.speed_raw",
              "poll_group": "fast",
              "function": "read_holding_registers",
              "address": 1,
              "data_type": "u16"
            },
            {
              "tag": "plc1.speed_rpm",
              "poll_group": "fast",
              "function": "read_holding_registers",
              "address": 2,
              "data_type": "u16",
              "formula": "raw * 60",
              "units": "rpm"
            },
            {
              "tag": "plc1.flow_total",
              "poll_group": "slow",
              "function": "read_holding_registers",
              "address": 10,
              "data_type": "u32",
              "word_order": "little_endian",
              "retentive": true,
              "retain_last": 100
            },
            {
              "tag": "plc1.run_cmd",
              "poll_group": "fast",
              "function": "read_coils",
              "address": 0,
              "data_type": "bit",
              "writable": true,
              "write_function": "write_multiple_coils"
            },
            {
              "tag": "plc1.setpoint",
              "poll_group": "fast",
              "function": "read_holding_registers",
              "address": 20,
              "data_type": "u16",
              "scale": 0.1,
              "units": "degC",
              "writable": true,
              "write_function": "write_multiple_registers"
            }
          ]
        }
      ]
    },
    {
      "id": "rs485-line-1",
      "enabled": false,
      "transport": {
        "type": "rtu",
        "path": "COM3",
        "baud": 9600,
        "parity": "none",
        "stop_bits": 1
      },
      "request_timeout_ms": 500,
      "inter_request_delay_ms": 20,
      "devices": [
        {
          "id": "meter1",
          "unit_id": 5,
          "registers": [
            {
              "tag": "meter1.energy",
              "poll_group": "slow",
              "function": "read_input_registers",
              "address": 100,
              "data_type": "f32",
              "word_order": "little_endian",
              "units": "kWh",
              "retentive": true
            }
          ]
        }
      ]
    }
  ]
}