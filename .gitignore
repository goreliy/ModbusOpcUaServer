# --- Rust / Cargo ---
# Build artifacts (workspace root and any nested crate).
/target/
**/target/
# rustfmt / merge backups.
**/*.rs.bk
*.rs.orig
# Native debug symbols.
*.pdb
# Cargo.lock IS committed on purpose: this workspace ships binaries, and a
# locked dependency graph keeps builds reproducible.

# --- Runtime state the server creates next to its config ---
/data/
/logs/
/pki/
*.log

# --- Generated distribution packages ---
# Linux packages are rebuilt on demand (installers/linux/*.sh, see
# installers/README.md) and belong in GitHub Releases, not in the tree.
# The Windows deliverables in /dist/windows/ ARE committed deliberately —
# the README download links point straight at them.
/dist/linux/
/dist/linux-arm64/

# --- IDE / editors ---
.vscode/
.idea/
*.iml

# --- Local assistant state ---
/.claude/

# --- OS junk ---
.DS_Store
Thumbs.db
desktop.ini
