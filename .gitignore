# Rust/Cargo build artifacts
/target/
**/target/

# Runtime state and generated credentials
/data/
/pki/
/logs/

# Local assistant/editor state
/.claude/

# Old generated Linux packages are built on demand and published as releases,
# not stored in the source tree. Deliberate Windows deliverables live in
# /dist/windows/ and remain visible to Git.
/dist/linux/
/dist/linux-arm64/

# Backup files created by rustfmt and editors
**/*.rs.bk
*.rs.orig

# Logs
*.log

# IDE/editor directories
.vscode/
.idea/
*.iml

# OS generated files
.DS_Store
Thumbs.db
desktop.ini
